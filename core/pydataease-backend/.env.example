# Environment: dev or prod
DE_ENV=dev

# Application
DE_APP_NAME=DataEase API
DE_DEBUG=true
DE_PORT=8000
DE_TASK_CLEANUP_INTERVAL_MINUTES=60
DE_EXPORT_POLL_INTERVAL_SECONDS=30

# Database
DE_DATABASE_URL=postgresql+asyncpg://dataease:dataease@localhost:5432/dataease

# Security
DE_SECRET_KEY=change-me-in-production
DE_SHARE_SECRET_KEY=change-me-in-production
