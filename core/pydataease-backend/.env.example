# Environment: dev or prod
DE_ENV=dev

# Application
DE_APP_NAME=DataEase API
DE_DEBUG=true
DE_PORT=8000
DE_TASK_CLEANUP_INTERVAL_MINUTES=60
DE_EXPORT_POLL_INTERVAL_SECONDS=30

# Database
DE_DATABASE_URL=postgresql+asyncpg://dataease:dataease@localhost:5432/dataease

# Security
DE_SECRET_KEY=change-me-in-production
DE_SHARE_SECRET_KEY=change-me-in-production

# RSA key pair for login encryption
# If set, the private key is loaded from this PEM file (persistent across restarts).
# If unset, a new RSA-2048 key pair is generated on each process start — tokens
# encrypted by a previous key pair will fail to decrypt after restart.
DE_RSA_PRIVATE_KEY_PATH=rsa_private.pem

# CORS allowed origins (comma-separated, or * for all)
DE_CORS_ORIGINS=*

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
DE_LOG_LEVEL=INFO
