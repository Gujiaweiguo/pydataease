# =============================================
# PyDataEase 生产环境配置
# 复制此文件为 install.env，修改后执行 ./install.sh
# =============================================

# ---- [安装目录] ----
# 所有持久化数据的根路径
DE_INSTALL_DIR=/opt/module/pydataease

# ---- [对外服务] ----
# 用户浏览器访问的端口
DE_PORT=8100

# ---- [必改] 安全密钥 ----
# JWT 签名密钥（建议 32 位以上随机字符串，可用 openssl rand -hex 32 生成）
DE_SECRET_KEY=
# 分享 Token 签名密钥（必须与 DE_SECRET_KEY 不同）
DE_SHARE_SECRET_KEY=

# ---- [管理员账号] ----
# 管理员用户名（默认 admin，一般不需要修改）
DE_ADMIN_USERNAME=admin
# 管理员初始密码（首次安装时设置，不能为空）
DE_ADMIN_PASSWORD=

# ---- [数据库模式] builtin=自带PG容器  external=使用已有PG ----
DE_PG_MODE=builtin

# ---- [builtin 模式配置] ----
# 内置 PostgreSQL 密码
DE_PG_PASSWORD=
# 离线镜像目录（留空则从 registry 拉取，离线安装时指向包含 tar 文件的目录）
DE_IMAGE_DIR=

# ---- [external 模式配置] (DE_PG_MODE=external 时生效) ----
DE_DATABASE_HOST=
DE_DATABASE_PORT=5432
DE_DATABASE_NAME=dataease
DE_DATABASE_USER=
DE_DATABASE_PASSWORD=
DE_DATABASE_SSLMODE=prefer
# 是否允许安装脚本在外部 PG 上自动创建数据库和扩展（默认 false，需 DBA 手动创建）
DE_PG_ALLOW_INIT=false

# ---- [可选] 功能配置 ----
# CORS 允许的源（逗号分隔，* 表示全部）
DE_CORS_ORIGINS=*
# 日志级别（DEBUG, INFO, WARNING, ERROR, CRITICAL）
DE_LOG_LEVEL=INFO
# 数据库连接池大小
DE_DB_POOL_SIZE=10
# RSA 私钥路径（不设则每次重启重新生成，导致登录 Token 解密失败）
DE_RSA_PRIVATE_KEY_PATH=

# ---- [升级/备份] ----
# 升级前是否自动备份数据库
DE_BACKUP_BEFORE_UPGRADE=true
# 备份目录（默认 ${DE_INSTALL_DIR}/data/backups）
DE_BACKUP_DIR=

# ---- [应用版本] ----
# 镜像标签版本号（一般不需要修改，由安装包自带）
DE_APP_VERSION=2.10
